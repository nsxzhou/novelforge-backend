server:
  host: "0.0.0.0"
  port: 8080
  read_timeout_seconds: 15
  write_timeout_seconds: 15

storage:
  provider: "postgres"
  postgres:
    url_env: "NOVELFORGE_DATABASE_URL"
    max_open_conns: 10
    max_idle_conns: 5
    conn_max_lifetime_seconds: 300

llm:
  provider: "placeholder"
  model: "placeholder-model"
  base_url: ""
  api_key_env: "NOVELFORGE_LLM_API_KEY"
